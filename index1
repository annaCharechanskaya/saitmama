<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Галина Бухгалтер | стаж 20+ лет, услуги, отзывы</title>
    <!-- Google Fonts & Font Awesome -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f4f1fe;
            min-height: 100vh;
            padding: 20px;
            color: #1e1e2f;
            line-height: 1.5;
        }

        .page {
            max-width: 1300px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-radius: 56px;
            box-shadow: 0 30px 60px -20px rgba(28, 28, 80, 0.25);
            border: 1px solid rgba(255,255,255,0.7);
            padding: 40px 45px 50px;
        }

        .hero {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 30px;
            margin-bottom: 45px;
        }

        .avatar {
            background: linear-gradient(135deg, #5a45a0, #392e68);
            width: 120px;
            height: 120px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 52px;
            font-weight: 500;
            box-shadow: 0 18px 25px -8px #2e2755;
            border: 4px solid white;
        }

        .title-section h1 {
            font-size: 3rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            background: linear-gradient(130deg, #1d1242, #4a3592);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 5px;
        }

        .title-section .sub {
            font-size: 1.3rem;
            font-weight: 500;
            color: #423b63;
            background: rgba(230, 220, 255, 0.6);
            display: inline-block;
            padding: 6px 20px;
            border-radius: 60px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255,255,255,0.7);
        }

        /* сетка: услуги + прайс/контакты */
        .grid-main {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 30px;
            margin-bottom: 40px;
        }

        .services, .right-panel {
            background: rgba(255, 255, 255, 0.55);
            backdrop-filter: blur(6px);
            border-radius: 36px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.7);
            box-shadow: 0 8px 22px rgba(0,0,0,0.02);
        }

        .services h2, .right-panel h2, .news-header h2, .reviews-header h2 {
            font-size: 1.9rem;
            font-weight: 600;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #26224b;
        }

        /* УСЛУГИ — динамический список */
        .service-items {
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        .service-item {
            display: flex;
            gap: 18px;
            align-items: flex-start;
        }
        .service-icon {
            background: white;
            width: 52px;
            height: 52px;
            border-radius: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #3f2b7a;
            box-shadow: 0 10px 15px -8px #b6abdf;
            flex-shrink: 0;
        }
        .service-text h3 {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 5px;
            color: #2b2350;
        }
        .service-text p {
            color: #3f3b5c;
        }

        /* ПРАЙС динамический */
        .price-list {
            list-style: none;
            margin-top: 15px;
        }
        .price-list li {
            display: flex;
            justify-content: space-between;
            padding: 14px 0;
            border-bottom: 1px dashed rgba(79, 67, 138, 0.2);
            font-size: 1.1rem;
            font-weight: 500;
        }
        .price-list li:last-child {
            border-bottom: none;
        }
        .price-value {
            background: #423a75;
            color: white;
            padding: 5px 18px;
            border-radius: 60px;
            font-weight: 600;
            font-size: 1rem;
        }

        /* Контакты Галины */
        .contact-block {
            margin-top: 25px;
        }
        .contact-item {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 18px;
            font-size: 1.15rem;
            background: rgba(255,255,255,0.5);
            padding: 8px 15px;
            border-radius: 50px;
            border: 1px solid white;
        }
        .contact-item i {
            width: 30px;
            font-size: 1.7rem;
            color: #392d68;
        }
        .tg-nick {
            background: #27A6E5;
            color: white;
            padding: 6px 20px;
            border-radius: 40px;
            font-weight: 600;
            text-decoration: none;
            margin-left: 10px;
        }
        .phone-number {
            font-weight: 700;
            color: #1b1240;
            letter-spacing: 0.5px;
        }

        /* новости */
        .news-section {
            background: rgba(255, 255, 255, 0.55);
            backdrop-filter: blur(6px);
            border-radius: 36px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.7);
            margin-top: 30px;
        }
        .news-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            margin-bottom: 10px;
        }
        .admin-badge {
            background: #4d3a8b;
            color: white;
            padding: 8px 22px;
            border-radius: 60px;
            font-size: 0.9rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            border: 1px solid #a594e0;
            transition: 0.2s;
        }
        .admin-badge:hover {
            background: #372d5e;
        }

        .news-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            margin-top: 15px;
        }
        .news-card {
            background: white;
            border-radius: 28px;
            padding: 22px;
            box-shadow: 0 10px 16px -12px rgba(0,0,0,0.1);
            border: 1px solid rgba(255,255,255,0.8);
        }
        .news-date {
            font-size: 0.85rem;
            color: #6f64a3;
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 10px;
        }
        .news-title {
            font-weight: 700;
            font-size: 1.3rem;
            margin-bottom: 8px;
            color: #1b153b;
        }
        .news-preview {
            color: #4a436b;
        }

        /* ОТЗЫВЫ */
        .reviews-section {
            background: rgba(255, 255, 255, 0.55);
            backdrop-filter: blur(6px);
            border-radius: 36px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.7);
            margin-top: 30px;
        }
        .reviews-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }
        .review-card {
            background: white;
            border-radius: 24px;
            padding: 20px;
            box-shadow: 0 8px 14px -8px rgba(0,0,0,0.1);
            border: 1px solid rgba(255,255,255,0.8);
        }
        .review-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }
        .review-avatar {
            width: 48px;
            height: 48px;
            background: linear-gradient(145deg, #6d4fc9, #4a3592);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 20px;
        }
        .review-name {
            font-weight: 700;
            font-size: 1.1rem;
            color: #1b153b;
        }
        .review-date {
            font-size: 0.8rem;
            color: #6f64a3;
        }
        .review-text {
            color: #3f3b5c;
            line-height: 1.5;
        }
        .review-form {
            background: rgba(255,255,255,0.5);
            border-radius: 28px;
            padding: 25px;
            margin-top: 20px;
            border: 1px solid white;
        }
        .review-form h3 {
            font-size: 1.4rem;
            margin-bottom: 15px;
            color: #26224b;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .form-group input, .form-group textarea {
            width: 100%;
            padding: 14px 20px;
            border-radius: 50px;
            border: 1px solid #d0c0ff;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            background: white;
        }
        .form-group textarea {
            border-radius: 30px;
            resize: vertical;
            min-height: 100px;
        }
        .submit-btn {
            background: #4d3a8b;
            color: white;
            border: none;
            padding: 14px 32px;
            border-radius: 60px;
            font-weight: 600;
            font-size: 1.1rem;
            cursor: pointer;
            transition: 0.2s;
            border: 1px solid #a594e0;
        }
        .submit-btn:hover {
            background: #372d5e;
        }

        /* Админка (с паролем) */
        .admin-login-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(5px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .admin-login-box {
            background: white;
            border-radius: 48px;
            padding: 40px;
            max-width: 400px;
            width: 90%;
            box-shadow: 0 30px 50px rgba(0,0,0,0.3);
        }
        .admin-login-box h3 {
            font-size: 2rem;
            color: #26224b;
            margin-bottom: 20px;
        }
        .admin-login-box input {
            width: 100%;
            padding: 16px 20px;
            border-radius: 60px;
            border: 2px solid #d0c0ff;
            font-size: 1.1rem;
            margin-bottom: 20px;
        }
        .admin-login-box button {
            background: #4d3a8b;
            color: white;
            border: none;
            padding: 16px;
            border-radius: 60px;
            font-weight: 700;
            font-size: 1.2rem;
            width: 100%;
            cursor: pointer;
            margin-bottom: 10px;
        }
        .admin-login-box button:last-child {
            background: #888;
        }
        .admin-panel {
            background: rgba(40, 30, 70, 0.95);
            backdrop-filter: blur(12px);
            color: white;
            border-radius: 48px;
            padding: 30px;
            margin-top: 30px;
            display: none;
            border: 1px solid #b09ee0;
        }
        .admin-panel.show {
            display: block;
        }
        .admin-panel h3 {
            font-size: 1.8rem;
            margin-bottom: 20px;
            color: #eadcff;
        }
        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }
        .admin-group {
            background: #322d4e;
            border-radius: 28px;
            padding: 22px;
        }
        .admin-group label {
            display: block;
            font-weight: 500;
            margin: 12px 0 5px;
            color: #cfc3ff;
        }
        .admin-group input, .admin-group textarea {
            width: 100%;
            padding: 12px 18px;
            border-radius: 40px;
            border: none;
            background: #eeeaff;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            margin-bottom: 8px;
        }
        .admin-group button {
            background: #aa94f0;
            border: none;
            padding: 14px 28px;
            border-radius: 60px;
            font-weight: 700;
            font-size: 1.1rem;
            color: #1a123b;
            cursor: pointer;
            margin-top: 10px;
            transition: 0.2s;
            border: 1px solid #d7c9ff;
        }
        .admin-group button:hover {
            background: #c7b8ff;
        }
        .admin-group .remove-btn {
            background: #b44d6b;
            color: white;
            margin-left: 10px;
        }
        .close-admin {
            float: right;
            background: transparent;
            border: 2px solid white;
            color: white;
            padding: 8px 18px;
            border-radius: 60px;
            cursor: pointer;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .footer-note {
            margin-top: 35px;
            text-align: center;
            font-size: 0.95rem;
            color: #5e5585;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
            border-top: 1px dashed rgba(79, 67, 138, 0.25);
            padding-top: 25px;
        }

        @media (max-width: 900px) {
            .grid-main { grid-template-columns: 1fr; }
            .news-container { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
<div class="page" id="mainPage">

    <!-- Шапка -->
    <div class="hero">
        <div class="avatar"><i class="fas fa-calculator"></i></div>
        <div class="title-section">
            <h1>Галина Бухгалтер</h1>

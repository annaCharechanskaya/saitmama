        </div>
    </div>

    <!-- Основная сетка: услуги + прайс и контакты -->
    <div class="grid-main">
        <!-- левая колонка: УСЛУГИ динамические -->
        <div class="services" id="servicesBlock">
            <h2><i class="fas fa-briefcase"></i> Услуги</h2>
            <div class="service-items" id="serviceList"></div>
        </div>

        <!-- правая колонка: ПРАЙС + КОНТАКТЫ -->
        <div class="right-panel">
            <h2><i class="fas fa-tags"></i> Прайс‑лист</h2>
            <ul class="price-list" id="priceList"></ul>

            <!-- Контакты Галины -->
            <div class="contact-block">
                <div class="contact-item"><i class="fab fa-telegram"></i> Telegram: <a href="https://t.me/GalinaCha" target="_blank" class="tg-nick"><i class="fab fa-telegram"></i> @GalinaCha</a></div>
                <div class="contact-item"><i class="fas fa-phone-alt"></i> <span class="phone-number" id="galinaPhone">+7 (917) 593-31-23</span> (Галина)</div>
                <div class="contact-item"><i class="fas fa-envelope"></i> galina.buh@yandex.ru</div>
            </div>
        </div>
    </div>

    <!-- НОВОСТИ -->
    <div class="news-section">
        <div class="news-header">
            <h2><i class="far fa-newspaper"></i> Новости бухгалтера</h2>
            <div class="admin-badge" id="adminToggleBtn"><i class="fas fa-lock"></i> Вход для администратора</div>
        </div>
        <div class="news-container" id="newsContainer"></div>
    </div>

    <!-- ОТЗЫВЫ КЛИЕНТОВ (можно посмотреть и написать) -->
    <div class="reviews-section">
        <h2><i class="fas fa-star"></i> Отзывы клиентов</h2>
        <div class="reviews-container" id="reviewsContainer"></div>
        
        <!-- Форма добавления отзыва -->
        <div class="review-form">
            <h3><i class="fas fa-pen"></i> Оставить отзыв</h3>
            <div class="form-group">
                <input type="text" id="reviewName" placeholder="Ваше имя" maxlength="50">
            </div>
            <div class="form-group">
                <textarea id="reviewText" placeholder="Ваш отзыв" maxlength="500"></textarea>
            </div>
            <button class="submit-btn" id="submitReviewBtn"><i class="fas fa-paper-plane"></i> Отправить отзыв</button>
        </div>
    </div>

    <!-- АДМИНКА (вход по паролю) -->
    <div class="admin-login-overlay" id="adminLoginOverlay">
        <div class="admin-login-box">
            <h3><i class="fas fa-lock"></i> Вход в админку</h3>
            <input type="password" id="adminPassword" placeholder="Введите пароль" value="">
            <button id="checkPasswordBtn">Войти</button>
            <button id="cancelPasswordBtn">Отмена</button>
        </div>
    </div>

    <div class="admin-panel" id="adminPanel">
        <button class="close-admin" id="closeAdminBtn"><i class="fas fa-times"></i> Закрыть админку</button>
        <h3><i class="fas fa-cog"></i> Управление контентом</h3>
        <div class="admin-grid">
            <!-- Управление услугами -->
            <div class="admin-group">
                <h4>📋 Услуги (можно добавить/удалить)</h4>
                <div id="servicesAdminContainer"></div>
                <button id="addServiceBtn"><i class="fas fa-plus"></i> Добавить услугу</button>
                <button id="updateServicesBtn" style="margin-left:10px;">Сохранить услуги</button>
            </div>
            <!-- Управление прайсом -->
            <div class="admin-group">
                <h4>💰 Прайс-лист</h4>
                <div id="priceAdminContainer"></div>
                <button id="addPriceBtn"><i class="fas fa-plus"></i> Добавить позицию</button>
                <button id="updatePriceBtn" style="margin-left:10px;">Обновить прайс</button>
            </div>
            <!-- Управление новостями -->
            <div class="admin-group">
                <h4>📰 Новости</h4>
                <label>Новость 1 (заголовок)</label>
                <input type="text" id="newsTitle1" placeholder="Заголовок">
                <label>Текст</label>
                <textarea id="newsText1" rows="2"></textarea>
                <label>Дата</label>
                <input type="text" id="newsDate1" placeholder="12.03.2026">
                <label>Новость 2 (заголовок)</label>
                <input type="text" id="newsTitle2" placeholder="Заголовок">
                <label>Текст</label>
                <textarea id="newsText2" rows="2"></textarea>
                <label>Дата</label>
                <input type="text" id="newsDate2" placeholder="15.03.2026">
                <button id="updateNewsBtn">Обновить новости</button>
            </div>
            <!-- Управление отзывами (модерация) -->
            <div class="admin-group">
                <h4>⭐ Отзывы (модерация)</h4>
                <div id="reviewsAdminContainer"></div>
                <button id="saveReviewsBtn">Сохранить изменения</button>
            </div>
        </div>
        <p style="color:#c1b3f0; margin-top:20px;"><i class="fas fa-info-circle"></i> Данные сохраняются в браузере (localStorage). Пароль: 12345</p>
    </div>

    <!-- подвал -->
    <div class="footer-note">
        <span><i class="far fa-calendar"></i> Стаж более 20 лет</span>
        <span><i class="fas fa-phone-alt"></i> Галина: +7 (917) 593-31-23</span>
        <span><i class="fab fa-telegram"></i> <a href="https://t.me/GalinaCha" style="color:#382e6b;">@GalinaCha</a></span>
    </div>
</div>

<script>
(function() {
    // Пароль для входа в админку
    const ADMIN_PASSWORD = "12345";

    // ----- данные по умолчанию -----
    const defaultServices = [
        { icon: 'file-invoice', name: 'Отчетность под ключ', desc: 'Декларации, РСВ, СЗВ‑М, 6‑НДФЛ, ЕФС‑1. Без штрафов.' },
        { icon: 'hand-holding-usd', name: 'Сопровождение ИП', desc: 'УСН, патент, ОСН. Расчёт налогов, платежки.' },
        { icon: 'calculator', name: 'Учёт и оптимизация', desc: 'Зарплата, кадры, основные средства. Помощь в снижении налогов.' }
    ];
    const defaultPrices = [
        { name: '📄 Отчетность (1 отчёт)', value: '2 500 ₽' },
        { name: '📊 Ежемесячное обслуживание ИП', value: '12 000 ₽' },
        { name: '📦 Регистрация ИП под ключ', value: '5 500 ₽' },
        { name: '📎 Нулевая отчетность (квартал)', value: '3 000 ₽' }
    ];
    const defaultNews = [
        { title: 'Изменения в НДС с 2026 года', text: 'ФНС опубликовала разъяснения по новым ставкам. Консультирую по переходу.', date: '10.03.2026' },
        { title: 'Сроки сдачи отчётов за 1 квартал', text: 'Декларации по УСН и 6‑НДФЛ жду до 25 апреля. Записывайтесь.', date: '05.03.2026' }
    ];
    const defaultReviews = [
        { name: 'Елена', text: 'Очень довольна работой Галины! Всё вовремя, всегда на связи. Рекомендую!', date: '01.03.2026' },
        { name: 'Иван', text: 'Профессионал своего дела. Помогла разобраться с налогами и оптимизировать расходы.', date: '15.02.2026' }
    ];

    // ------ ЗАГРУЗКА / СОХРАНЕНИЕ ------
    function loadServices() {
        let s = localStorage.getItem('galinaServices');
        return s ? JSON.parse(s) : defaultServices;
    }
    function saveServices(services) {
        localStorage.setItem('galinaServices', JSON.stringify(services));
    }
    function loadPrices() {
        let p = localStorage.getItem('galinaPrices');
        return p ? JSON.parse(p) : defaultPrices;
    }
    function savePrices(prices) {
        localStorage.setItem('galinaPrices', JSON.stringify(prices));
    }
    function loadNews() {
        let n = localStorage.getItem('galinaNews');
        return n ? JSON.parse(n) : defaultNews;
    }
    function saveNews(news) {
        localStorage.setItem('galinaNews', JSON.stringify(news));
    }
    function loadReviews() {
        let r = localStorage.getItem('galinaReviews');
        return r ? JSON.parse(r) : defaultReviews;
    }
    function saveReviews(reviews) {
        localStorage.setItem('galinaReviews', JSON.stringify(reviews));
    }

    // ------ ОТРИСОВКА ------
    function renderServices() {
        const services = loadServices();
        const container = document.getElementById('serviceList');
        container.innerHTML = services.map(s => `
            <div class="service-item">
                <div class="service-icon"><i class="fas fa-${s.icon}"></i></div>
                <div class="service-text"><h3>${s.name}</h3><p>${s.desc}</p></div>
            </div>
        `).join('');
    }

    function renderPrices() {
        const prices = loadPrices();
        const container = document.getElementById('priceList');
        container.innerHTML = prices.map(p => `
            <li><span>${p.name}</span> <span class="price-value">${p.value}</span></li>
        `).join('');
    }

    function renderNews() {
        const news = loadNews();
        const container = document.getElementById('newsContainer');
        container.innerHTML = news.map(n => `
            <div class="news-card">
                <div class="news-date"><i class="far fa-calendar-alt"></i> ${n.date}</div>
                <div class="news-title">${n.title}</div>
                <div class="news-preview">${n.text}</div>
            </div>
        `).join('');
        // заполнить поля админки новостей
        if (news[0]) { 
            document.getElementById('newsTitle1').value = news[0].title; 
            document.getElementById('newsText1').value = news[0].text; 
            document.getElementById('newsDate1').value = news[0].date; 
        }
        if (news[1]) { 
            document.getElementById('newsTitle2').value = news[1].title; 
            document.getElementById('newsText2').value = news[1].text; 
            document.getElementById('newsDate2').value = news[1].date; 
        }
    }

    function renderReviews() {
        const reviews = loadReviews();
        const container = document.getElementById('reviewsContainer');
        container.innerHTML = reviews.map(r => `
            <div class="review-card">
                <div class="review-header">
                    <div class="review-avatar">${r.name.charAt(0)}</div>
                    <div>
                        <div class="review-name">${r.name}</div>
                        <div class="review-date">${r.date}</div>
                    </div>
                </div>
                <div class="review-text">${r.text}</div>
            </div>
        `).join('');
    }

    // ------ АДМИНКА: услуги + прайс + отзывы ------
    function renderAdminServices() {
        const services = loadServices();
        const container = document.getElementById('servicesAdminContainer');
        container.innerHTML = services.map((s, index) => `
            <div style="border-bottom: 1px solid #665a99; padding:10px 0;">
                <label>Услуга ${index+1} (название)</label>
                <input type="text" class="admin-service-name" data-index="${index}" value="${s.name.replace(/"/g, '&quot;')}">
                <label>Описание</label>
                <input type="text" class="admin-service-desc" data-index="${index}" value="${s.desc.replace(/"/g, '&quot;')}">
                <label>Иконка (fa-xxxx, например file-invoice)</label>
                <input type="text" class="admin-service-icon" data-index="${index}" value="${s.icon}">
                <button class="remove-btn" onclick="removeService(${index})">Удалить</button>
            </div>
        `).join('');
    }

    function renderAdminPrices() {
        const prices = loadPrices();
        const container = document.getElementById('priceAdminContainer');
        container.innerHTML = prices.map((p, index) => `
            <div style="border-bottom: 1px solid #665a99; padding:10px 0;">
                <label>Название</label>
                <input type="text" class="admin-price-name" data-index="${index}" value="${p.name.replace(/"/g, '&quot;')}">
                <label>Цена</label>
                <input type="text" class="admin-price-value" data-index="${index}" value="${p.value}">
                <button class="remove-btn" onclick="removePrice(${index})">Удалить</button>
            </div>
        `).join('');
    }

    function renderAdminReviews() {
        const reviews = loadReviews();
        const container = document.getElementById('reviewsAdminContainer');
        container.innerHTML = reviews.map((r, index) => `
            <div style="border-bottom: 1px solid #665a99; padding:15px 0;">
                <label>Имя</label>
                <input type="text" class="admin-review-name" data-index="${index}" value="${r.name.replace(/"/g, '&quot;')}">
                <label>Отзыв</label>
                <textarea class="admin-review-text" data-index="${index}" rows="2">${r.text.replace(/"/g, '&quot;')}</textarea>
                <label>Дата</label>
                <input type="text" class="admin-review-date" data-index="${index}" value="${r.date}">
                <button class="remove-btn" onclick="removeReview(${index})">Удалить</button>
            </div>
        `).join('');
    }

    // глобальные функции для кнопок удалить
    window.removeService = function(index) {
        let services = loadServices();
        services.splice(index, 1);
        saveServices(services);
        renderServices();
        renderAdminServices();
    };
    window.removePrice = function(index) {
        let prices = loadPrices();
        prices.splice(index, 1);
        savePrices(prices);
        renderPrices();
        renderAdminPrices();
    };
    window.removeReview = function(index) {
        let reviews = loadReviews();
        reviews.splice(index, 1);
        saveReviews(reviews);
        renderReviews();
        renderAdminReviews();
    };

    // ------ СОБЫТИЯ ------
    document.addEventListener('DOMContentLoaded', function() {
        // Первичная отрисовка
        renderServices();
        renderPrices();
        renderNews();
        renderReviews();

        // ---- Админка с паролем ----
        const overlay = document.getElementById('adminLoginOverlay');
        const adminPanel = document.getElementById('adminPanel');
        
        document.getElementById('adminToggleBtn').addEventListener('click', function() {
            overlay.style.display = 'flex';
        });

        document.getElementById('checkPasswordBtn').addEventListener('click', function() {
            const pwd = document.getElementById('adminPassword').value;
            if (pwd === ADMIN_PASSWORD) {
                overlay.style.display = 'none';
                adminPanel.classList.add('show');
                renderAdminServices();
                renderAdminPrices();
                renderAdminReviews();
                document.getElementById('adminPassword').value = '';
            } else {
                alert('Неверный пароль');
            }
        });

        document.getElementById('cancelPasswordBtn').addEventListener('click', function() {
            overlay.style.display = 'none';
            document.getElementById('adminPassword').value = '';
        });

        document.getElementById('closeAdminBtn').addEventListener('click', function() {
            adminPanel.classList.remove('show');
        });

        // Добавить услугу
        document.getElementById('addServiceBtn').addEventListener('click', function() {
            let services = loadServices();
            services.push({ icon: 'file', name: 'Новая услуга', desc: 'Описание' });
            saveServices(services);
            renderServices();
            renderAdminServices();
        });

        // Сохранить изменения услуг
        document.getElementById('updateServicesBtn').addEventListener('click', function() {
            let nameFields = document.querySelectorAll('.admin-service-name');
            let descFields = document.querySelectorAll('.admin-service-desc');
            let iconFields = document.querySelectorAll('.admin-service-icon');
            let services = [];
            for (let i=0; i<nameFields.length; i++) {
                services.push({
                    name: nameFields[i].value,
                    desc: descFields[i].value,
                    icon: iconFields[i].value
                });
            }
            saveServices(services);
            renderServices();
            renderAdminServices();
        });

        // Добавить позицию прайса
        document.getElementById('addPriceBtn').addEventListener('click', function() {
            let prices = loadPrices();
            prices.push({ name: 'Новая услуга', value: '0 ₽' });
            savePrices(prices);
            renderPrices();
            renderAdminPrices();
        });

        // Обновить прайс
        document.getElementById('updatePriceBtn').addEventListener('click', function() {
            let nameFields = document.querySelectorAll('.admin-price-name');
            let valueFields = document.querySelectorAll('.admin-price-value');
            let prices = [];
            for (let i=0; i<nameFields.length; i++) {
                prices.push({ name: nameFields[i].value, value: valueFields[i].value });
            }
            savePrices(prices);
            renderPrices();
            renderAdminPrices();
        });

        // Обновить новости
        document.getElementById('updateNewsBtn').addEventListener('click', function() {
            let news = [
                { title: document.getElementById('newsTitle1').value, text: document.getElementById('newsText1').value, date: document.getElementById('newsDate1').value },
                { title: document.getElementById('newsTitle2').value, text: document.getElementById('newsText2').value, date: document.getElementById('newsDate2').value }
            ];
            saveNews(news);
            renderNews();
        });

        // Сохранить изменения отзывов (из админки)
        document.getElementById('saveReviewsBtn').addEventListener('click', function() {
            let nameFields = document.querySelectorAll('.admin-review-name');
            let textFields = document.querySelectorAll('.admin-review-text');
            let dateFields = document.querySelectorAll('.admin-review-date');
            let reviews = [];
            for (let i=0; i<nameFields.length; i++) {
                if (nameFields[i].value.trim() !== '' || textFields[i].value.trim() !== '') {
                    reviews.push({
                        name: nameFields[i].value.trim() || 'Аноним',
                        text: textFields[i].value.trim() || '...',
                        date: dateFields[i].value || new Date().toLocaleDateString('ru-RU')
                    });
                }
            }
            saveReviews(reviews);
            renderReviews();
            renderAdminReviews();
        });

        // Добавление отзыва через форму на странице
        document.getElementById('submitReviewBtn').addEventListener('click', function() {
            const name = document.getElementById('reviewName').value.trim();
            const text = document.getElementById('reviewText').value.trim();
            if (!name || !text) {
                alert('Пожалуйста, заполните имя и отзыв');
                return;
            }
            let reviews = loadReviews();
            const date = new Date().toLocaleDateString('ru-RU');
            reviews.push({ name, text, date });
            saveReviews(reviews);
            renderReviews();
            // Очистить форму
            document.getElementById('reviewName').value = '';
            document.getElementById('reviewText').value = '';
            alert('Спасибо за отзыв!');
        });
    });
})();
</script>
</body>
</html>
